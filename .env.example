# ─── OpenAI / LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here

# Optional: use a different base URL (e.g. Azure OpenAI, Together AI, Ollama)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model for chat completions
OPENAI_MODEL=gpt-4.1-mini

# Model for embeddings (must produce 1536-dim vectors for the default schema)
EMBEDDING_MODEL=text-embedding-3-small

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio

# ─── Next.js ───────────────────────────────────────────────────────────────────
# URL of the FastAPI server (used server-side by Next.js API route)
FASTAPI_URL=http://localhost:8000

# ─── RAG Parameters ────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
